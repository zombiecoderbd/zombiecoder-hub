# ============================================================================
# ZombieCoder Hub v2.0 - Environment Configuration
# ============================================================================
# 
# Copy this file to .env.local and configure for your environment
# Compatible with Windows and Linux
#

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

NODE_ENV=development
APP_URL=http://localhost:3000
APP_PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# 
# SQLite (Default - Local Development)
# DATABASE_URL="file:./prisma/dev.db"
#
# For production, consider using:
# - PostgreSQL: postgresql://user:password@localhost:5432/zombiecoder
# - MySQL: mysql://user:password@localhost:3306/zombiecoder
#

DATABASE_URL="file:./prisma/dev.db"

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret Key (Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_IN=24h

# Admin JWT Secret (Change this in production!)
ADMIN_JWT_SECRET=your-admin-secret-change-in-production

# Admin session timeout in milliseconds (30 minutes default)
ADMIN_SESSION_TIMEOUT=1800000

# ============================================================================
# AI PROVIDERS - Multi-Provider Support
# ============================================================================
#
# ZombieCoder supports multiple AI providers:
# 1. Ollama (Recommended for local-first operation)
# 2. OpenAI (GPT-4 Turbo, etc.)
# 3. Google Gemini (Gemini Pro, etc.)
#
# Provider Priority: Ollama → OpenAI → Gemini (with fallback)
#

# --- OLLAMA (Local LLM - Primary Provider) ---
# Start Ollama locally: ollama pull smollm:latest && ollama serve
# Default: http://localhost:11434

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud
OLLAMA_API_KEY=a2f49bed2aba464ca27efd45a4bbe75d.Nj2W62RDnJfxQf_-9Tjy_2JC

# Alternative models: neural-chat, deepseek-r1:1.5b, openchat, orca-mini, etc.
# OLLAMA_MODEL=neural-chat

# --- OPENAI (Cloud-based AI) ---
# Get API key from: https://platform.openai.com/api-keys
# Leave blank to disable OpenAI fallback

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# --- GOOGLE GEMINI (Cloud-based AI) ---
# Get API key from: https://makersuite.google.com/app/apikey
# Leave blank to disable Gemini fallback

GEMINI_API_KEY=AIzaSyB1hFbncerF7ZZ1sLz9NIOvFCnw6wmdMdM
GEMINI_MODEL=gemini-flash-latest

# ============================================================================
# MCP (Model Context Protocol) CONFIGURATION
# ============================================================================
#
# Supported Transports:
# - stdio  : Standard Input/Output (Default, best for local)
# - http   : HTTP/HTTPS REST API
# - sse    : Server-Sent Events (Real-time streaming)
# - websocket : WebSocket (Full-duplex communication)
#

MCP_TRANSPORT=stdio
MCP_PORT=3003
MCP_ENDPOINT=/mcp

# ============================================================================
# SYSTEM FEATURES & GOVERNANCE
# ============================================================================

# Enable Ethics Framework & Governance Validation
ENABLE_GOVERNANCE=true

# Enable Audit Logging for all operations
ENABLE_AUDIT_LOGGING=true

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# OPTIONAL: EDITOR EXTENSIONS & LSP/DAP
# ============================================================================

# Language Server Protocol (LSP) Configuration
LSP_PORT=2088
LSP_ENABLED=true

# Debug Adapter Protocol (DAP) Configuration
DAP_PORT=5005
DAP_ENABLED=true

# File Indexing Service
FILE_INDEXER_ENABLED=true

# ============================================================================
# WINDOWS & LINUX COMPATIBILITY NOTES
# ============================================================================
#
# Database Paths:
# - Windows: file:./prisma/dev.db or C:/path/to/db.db
# - Linux:   file:./prisma/dev.db or /path/to/db.db
#
# Environment variables are cross-platform compatible.
# Use forward slashes (/) for all paths - they work on both systems.
#
# For Windows users:
# - Use Git Bash or WSL for consistent command-line experience
# - Database will be created automatically in ./prisma/dev.db
# 
# For Linux users:
# - Ensure Node.js version 18+ is installed
# - Database directory must be writable by the Node process
# - Use 'chmod +x' for executable scripts
#
